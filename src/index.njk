---
layout: base.njk
title: Beranda
description: Kamus Aceh — kamus digital terbuka Bahasa Aceh–Indonesia–Inggris, lengkap dengan tulisan Jawi.
pagefind: true
---

<section class="hero">
  <div class="hero-badge">📖 Bahasa Aceh · بهاس اچيه</div>
  <h1 class="hero-title">
    Kamus <span>Aceh</span>
  </h1>
  <span class="hero-jawi">كاموس اچيه</span>
  <p class="hero-sub">Kamus digital terbuka · Aceh – Indonesia – Inggris – Jawi</p>
</section>

<div class="search-wrap">
  <div id="search"></div>
</div>

<div class="stats-bar">
  <div class="stat">
    <div class="stat-num">{{ collections.entries | length }}</div>
    <div class="stat-label">Entri</div>
  </div>
  <div class="stat">
    <div class="stat-num">3</div>
    <div class="stat-label">Bahasa</div>
  </div>
  <div class="stat">
    <div class="stat-num">Terbuka</div>
    <div class="stat-label">Lisensi CC-BY-SA</div>
  </div>
</div>

<p class="section-label">Contoh kata</p>

<div class="featured-grid">
  {% for entry in collections.entries | randomPick(6) %}
  <a class="entry-card" href="{{ ('/entries/' + (entry.data.headword | slugify) + '/') | url }}">
    <div class="card-hw">{{ entry.data.headword }}</div>
    {% if entry.data.jawi %}<div class="card-jawi">{{ entry.data.jawi }}</div>{% endif %}
    <div class="card-pos">{{ entry.data.part_of_speech }}</div>
    <div class="card-gloss">{{ entry.data.definitions[0].meaning_id }}</div>
  </a>
  {% endfor %}
</div>
