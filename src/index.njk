---
layout: base.njk
title: Beranda
description: Kamus Aceh — kamus digital open-source Bahasa Aceh–Indonesia–Inggris, lengkap dengan tulisan Jawi.
pagefind: true
---

<section class="hero">
  <div class="hero-badge">📖 Bahasa Aceh · بهاس اچيه</div>
  <h1 class="hero-title">
    Kamus <span>Aceh</span>
  </h1>
  <span class="hero-jawi">كاموس اچيه</span>
  <p class="hero-sub">Kamus digital open-source · Aceh – Indonesia – Inggris – Jawi</p>
</section>

<div class="search-wrap">
  <div id="search"></div>
</div>

<div class="stats-bar">
  <div class="stat">
    <div class="stat-num">{{ entries | length }}</div>
    <div class="stat-label">Entri</div>
  </div>
  <div class="stat">
    <div class="stat-num">3</div>
    <div class="stat-label">Bahasa</div>
  </div>
  <div class="stat">
    <div class="stat-num">Terbuka</div>
    <div class="stat-label">Open-Source</div>
  </div>
</div>

<p class="section-label">Contoh kata</p>

<div class="featured-grid">
  {% for entry in entries | randomPick(6) %}
  <a class="entry-card" href="{{ ('/entries/' + entry.fileSlug + '/') | url }}">
    <div class="card-hw">{{ entry.headword }}</div>
    {% if entry.jawi %}<div class="card-jawi">{{ entry.jawi }}</div>{% endif %}
    <div class="card-pos">{{ entry.part_of_speech }}</div>
    <div class="card-gloss">{{ entry.definitions[0].meaning_id }}</div>
  </a>
  {% endfor %}
</div>
